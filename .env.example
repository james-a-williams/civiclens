# Data source API keys
FEC_API_KEY=                  # api.data.gov/signup (same key works for Congress too)
CONGRESS_API_KEY=             # api.data.gov/signup (same key works for FEC too)
OPENSTATES_API_KEY=           # openstates.org/api/register
VOTESMART_API_KEY=            # votesmart.org/share/api
CENSUS_API_KEY=               # api.census.gov/data/key_signup.html
# OpenSecrets bulk data: no API key — account approval at opensecrets.org/bulk-data/signup, manual CSV download
# Senate roll-call votes: no key — public XML from senate.gov
# Wikipedia/Wikidata (bios): no key — User-Agent header only

# Snowflake
SNOWFLAKE_ACCOUNT=                                           # e.g. abc12345 or orgname-accountname
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/james/.ssh/snowflake_rsa_key.p8
SNOWFLAKE_ROLE=CIVICLENS
SNOWFLAKE_WAREHOUSE=CIVICLENS_WH
SNOWFLAKE_RAW_DATABASE=CIVICLENS_RAW
SNOWFLAKE_RAW_SCHEMA=PUBLIC
SNOWFLAKE_DATABASE=CIVICLENS

# Prefect
PREFECT_API_URL=
PREFECT_API_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Slack (monitor agent alerts)
SLACK_WEBHOOK_URL=
